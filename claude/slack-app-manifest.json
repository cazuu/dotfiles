{
  "display_information": {
    "name": "Claude Code Bridge",
    "description": "tmux 上の Claude Code の承認待ちを通知し、Slack から応答を返す"
  },
  "features": {
    "bot_user": {
      "display_name": "claude-code-bridge",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "reactions:add",
        "channels:history",
        "groups:history",
        "im:history"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "socket_mode_enabled": true
  }
}
